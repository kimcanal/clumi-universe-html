# Wrangler Workers Assets ignore list

# Git/build metadata
.git/
.wrangler/
node_modules/

# Local/system files
.DS_Store
serve.pid
*.log

# Repository-only files
.assetsignore
.gitignore
README.md
scripts/
wrangler.jsonc

# Menu automation helper files not used by the site
data/tossplace-menu/*/menu.csv
data/tossplace-menu/*/state.json
